bash tools/bench_plan_a.sh

# 只跑 BASELINE (iter=100, 30 秒, skip build if 已 build)
SKIP_BUILD=1 SKIP_PULL=1 bash tools/bench_plan_a.sh  # 不完全是 baseline-only, 脚本内会跑 BASELINE+PLAN_A

# 手动跑 BASELINE
cd /home/fizhang/test/mori && MORI_PIPELINE_CU=160 python3 tests/python/ccl/test_allreduce.py \
    --num-stages 4 --elems 67108864 --iterations 100 --warmup 20

# 手动跑 Plan A DIRECT
MORI_PIPELINE_CU=160 MORI_DIRECT_OUTPUT=1 python3 tests/python/ccl/test_allreduce.py \
    --num-stages 4 --elems 67108864 --iterations 100 --warmup 20

# Phase timing (iter=3 足够)
MORI_PIPELINE_CU=160 MORI_DIRECT_OUTPUT=1 MORI_PHASE_TARGET_STAGE=0 python3 tests/python/ccl/test_allreduce.py \
