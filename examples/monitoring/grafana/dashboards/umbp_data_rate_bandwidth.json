          },
          "expr": "rate(mori_umbp_client_get_bytes_total[30s])",
          "legendFormat": "{{node}} {{traffic}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 16,
      "title": "Total Data Rate (bytes/s)",
