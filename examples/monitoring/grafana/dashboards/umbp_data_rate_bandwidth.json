  "panels": [
    {
      "id": 14,
      "title": "Per-Client Write Data Rate (bytes/s)",
      "description": "Write data rate per client broken down by local vs remote traffic.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "rate(mori_umbp_client_put_bytes_total[30s])",
          "legendFormat": "{{node}} {{traffic}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 15,
      "title": "Per-Client Read Data Rate (bytes/s)",
      "description": "Read data rate per client broken down by local vs remote traffic.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
