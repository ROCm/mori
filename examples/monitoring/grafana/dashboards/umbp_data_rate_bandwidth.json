      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (traffic) (rate(mori_umbp_client_put_bytes_total[30s]))",
          "legendFormat": "write {{traffic}}",
          "refId": "A"
