{
  "title": "UMBP Master - Client Metrics",
  "uid": "a3c12b45-e7f9-4d82-b1a6-9e3f08c7d512",
  "tags": [
    "umbp",
    "clients"
  ],
  "schemaVersion": 36,
  "refresh": "5s",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "label": "Data Source",
        "pluginId": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "PBFA97CFB590B2093"
        },
        "hide": 0,
        "query": "prometheus"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Alive Client Count",
      "description": "Number of alive UMBP clients (SGLang workers) registered with the master.",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "mori_umbp_client_count",
          "legendFormat": "Clients",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Per-Client Total Capacity by Tier (bytes)",
      "description": "Total capacity reported by each client for each storage tier (HBM/DRAM/SSD).",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "{__name__=~\"mori_umbp_client_capacity_total_bytes_.+\"}",
          "legendFormat": "{{__name__}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Per-Client Available Capacity by Tier (bytes)",
      "description": "Available (free) capacity per client per tier. Drops as blocks are allocated.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "{__name__=~\"mori_umbp_client_capacity_available_bytes_.+\"}",
          "legendFormat": "{{__name__}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Per-Client RoutePut Rate (puts/s)",
      "description": "Rate of RoutePut calls targeting each client. Higher = that client is receiving more writes.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "rate({__name__=~\"mori_umbp_client_route_put_total_.+\"}[30s])",
          "legendFormat": "{{__name__}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Per-Client RouteGet Rate (gets/s)",
      "description": "Rate of RouteGet calls served by each client. Higher = that client is serving more reads.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "rate({__name__=~\"mori_umbp_client_route_get_total_.+\"}[30s])",
          "legendFormat": "{{__name__}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Per-Client Lookup (Exists) Rate (hits/s)",
      "description": "Rate of Lookup hits for keys stored on each client.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "rate({__name__=~\"mori_umbp_client_lookup_total_.+\"}[30s])",
          "legendFormat": "{{__name__}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Per-Client RPC Totals (Put / Get / Lookup)",
      "description": "Cumulative total RPC calls per client since master start.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "{__name__=~\"mori_umbp_client_route_put_total_.+\"}",
          "legendFormat": "put {{__name__}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "{__name__=~\"mori_umbp_client_route_get_total_.+\"}",
          "legendFormat": "get {{__name__}}",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "{__name__=~\"mori_umbp_client_lookup_total_.+\"}",
          "legendFormat": "lookup {{__name__}}",
          "refId": "C"
        }
      ]
    }
  ]
}
