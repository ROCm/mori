{
  "title": "UMBP Master - Client RPC Latency",
  "uid": "8c7d2f5a-6b9e-4d23-91a1-mori-rpc-lat",
  "tags": [
    "umbp",
    "master-client",
    "latency",
    "rpc"
  ],
  "schemaVersion": 36,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "label": "Data Source",
        "pluginId": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "PBFA97CFB590B2093"
        },
        "hide": 0,
        "query": "prometheus"
      },
      {
        "type": "query",
        "name": "node",
        "label": "Client (node label)",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(mori_umbp_master_client_rpc_latency_seconds_count, node)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "type": "query",
        "name": "rpc",
        "label": "RPC method",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(mori_umbp_master_client_rpc_latency_seconds_count, rpc)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "P99 Latency by RPC (excludes Heartbeat)",
      "description": "P99 client-perceived latency for each MasterClient RPC method, grouped by client (node). Heartbeat is filtered out by default to avoid masking real business RPC tail latency.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.99, sum by (le, rpc, node) (rate(mori_umbp_master_client_rpc_latency_seconds_bucket{status=\"ok\",rpc!=\"Heartbeat\",node=~\"$node\",rpc=~\"$rpc\"}[$__rate_interval])))",
          "legendFormat": "{{rpc}} @ {{node}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Selected RPC: P50 / P95 / P99 (per node)",
      "description": "Latency distribution for the selected RPC ($rpc) per client. Use the rpc template variable to focus on a single method including Heartbeat.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.50, sum by (le, rpc, node) (rate(mori_umbp_master_client_rpc_latency_seconds_bucket{status=\"ok\",node=~\"$node\",rpc=~\"$rpc\"}[$__rate_interval])))",
          "legendFormat": "p50 {{rpc}} @ {{node}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.95, sum by (le, rpc, node) (rate(mori_umbp_master_client_rpc_latency_seconds_bucket{status=\"ok\",node=~\"$node\",rpc=~\"$rpc\"}[$__rate_interval])))",
          "legendFormat": "p95 {{rpc}} @ {{node}}",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.99, sum by (le, rpc, node) (rate(mori_umbp_master_client_rpc_latency_seconds_bucket{status=\"ok\",node=~\"$node\",rpc=~\"$rpc\"}[$__rate_interval])))",
          "legendFormat": "p99 {{rpc}} @ {{node}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 3,
      "title": "QPS by RPC (excludes Heartbeat)",
      "description": "Successful RPC rate per method per client. Heartbeat (~0.2 Hz) excluded so business RPCs are visible.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (rpc, node) (rate(mori_umbp_master_client_rpc_latency_seconds_count{status=\"ok\",rpc!=\"Heartbeat\",node=~\"$node\",rpc=~\"$rpc\"}[$__rate_interval]))",
          "legendFormat": "{{rpc}} @ {{node}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Error rate by RPC + code",
      "description": "Non-OK RPC rate, broken down by gRPC status code (UNAVAILABLE, DEADLINE_EXCEEDED, ...).",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (rpc, code, node) (rate(mori_umbp_master_client_rpc_errors_total{node=~\"$node\",rpc=~\"$rpc\"}[$__rate_interval]))",
          "legendFormat": "{{rpc}} {{code}} @ {{node}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Client-side metrics dropped (cap pressure)",
      "description": "Histogram observations dropped client-side because pending_histograms_ hit the hard cap. Should be 0 in steady state; non-zero indicates QPS exceeds plan assumptions or master has been unreachable for many flush cycles.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "rate(mori_umbp_master_client_metrics_dropped_total{node=~\"$node\"}[$__rate_interval])",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ]
    }
  ]
}
